# Entorno: production | sandbox
APP_ENV=production

# Dominio principal (fallback de CORS)
APP_PRIMARY_DOMAIN=https://bonifaciossancarlos.com

# Origenes permitidos separados por coma
# Ejemplo sandbox:
# CORS_ALLOWED_ORIGINS=https://bonifaciossancarlos.com,https://bfx-int-k9m2q7v4x8p1r6t3.bonifaciossancarlos.com
CORS_ALLOWED_ORIGINS=https://bonifaciossancarlos.com

# Cookies de sesión (usar 1 y None para HTTPS)
COOKIE_SECURE=1
COOKIE_SAMESITE=None

# Base de datos
DB_HOST=localhost
DB_USER=TU_USUARIO_DB
DB_PASS=TU_PASSWORD_DB
DB_NAME=TU_BASE_DE_DATOS

# SoftRestaurant: recepción de sync (api/softrestaurant/sync.php)
# Debe coincidir con el valor que envían los scripts en softrestaurant-sync (cabecera X-API-Key).
SR_SYNC_API_KEY=

# SMTP (send.php)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=notificaciones@bonifaciossancarlos.com
SMTP_PASS=CAMBIA_ESTA_PASSWORD
MAIL_FROM=notificaciones@bonifaciossancarlos.com
SMTP_FROM_NAME=Bonifacio's Restaurant

# IMAP (email/inbox.php)
IMAP_HOST={imap.hostinger.com:993/imap/ssl}INBOX
IMAP_USER=info@bonifaciossancarlos.com
IMAP_PASS=CAMBIA_ESTA_PASSWORD

# Firebase Cloud Messaging (server key legacy)
FIREBASE_SERVER_KEY=
