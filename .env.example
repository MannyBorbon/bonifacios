# API URL for backend
VITE_API_URL=http://localhost:3001/api
VITE_APP_MODE=production
# Panel admin: botón flotante "Selector" + modal CircularSelector (producción incluida). Desactivar: 0
# VITE_ADMIN_CIRCULAR_SELECTOR=0
VITE_SANDBOX_HOSTS=
VITE_SANDBOX_LABEL=SANDBOX INTERNO

# Firebase Web Push (PWA)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_VAPID_KEY=

# Configuración SMTP para notificaciones por email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu-email@ejemplo.com
SMTP_PASS=tu-contraseña-de-aplicación
SMTP_FROM=notificaciones@bonifaciossancarlos.com
SMTP_FROM_NAME=Bonifacio's Restaurant
